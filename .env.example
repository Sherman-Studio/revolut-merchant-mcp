# Revolut Merchant API secret key. Sandbox keys come from the Revolut
# Sandbox Business dashboard (Merchant API section).
REVOLUT_MERCHANT_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxx

# Merchant API version (sent as the Revolut-Api-Version header).
REVOLUT_API_VERSION=2024-09-01

# Sandbox by default. Set to false ONLY for production (also requires the
# acknowledgement flag below).
REVOLUT_SANDBOX=true
# REVOLUT_I_UNDERSTAND_PRODUCTION=true

# Read-only by default. Enable to register the create_* / cancel_* tools.
REVOLUT_MCP_ALLOW_WRITES=false
